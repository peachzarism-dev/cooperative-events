# ============================================================
# .env.local.example
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# ============================================================

# Supabase — ดูได้จาก Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role (สำหรับ admin operations — ห้าม expose ใน client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend API — สำหรับส่ง Email
RESEND_API_KEY=re_xxxxxxxxxxxx

# URL ของเว็บไซต์ (สำหรับสร้าง link ใน email)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email ที่ใช้ส่ง (ต้องยืนยัน domain ใน Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=ระบบลงทะเบียนกิจกรรม
